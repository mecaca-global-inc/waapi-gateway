# Gateway HTTP listen address
HTTP_ADDR=:3000

# Database: "sqlite3" (default) or "postgres"
DB_DIALECT=sqlite3
DB_URI=file:storages/gateway.db?_foreign_keys=on
# Postgres example:
# DB_DIALECT=postgres
# DB_URI=postgres://gateway:gateway@localhost:5432/gateway?sslmode=disable

# Admin login for the dashboard / POST /api/login
# REQUIRED: pick a strong password. The gateway refuses to start with
# admin/changeme/password/empty unless ALLOW_WEAK_AUTH=1.
ADMIN_USER=admin
ADMIN_PASS=please-change-me
# ALLOW_WEAK_AUTH=1   # local development only

# CORS — comma-separated origins, "*" for any (dev only)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=info

# Media work dir
MEDIA_DIR=storages/media

# Label shown in WhatsApp "Linked Devices" screen on the phone
DEVICE_NAME=WAAPI Gateway

# Dashboard build-time variable (Next.js)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3000
